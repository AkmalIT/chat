<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Chat</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          sans-serif;
        background: #343541;
        color: #fff;
        display: flex;
        height: 100vh;
      }

      .sidebar {
        width: 260px;
        background: #202123;
        padding: 10px;
        display: flex;
        flex-direction: column;
      }

      .new-chat-btn {
        background: #565869;
        border: 1px solid #565869;
        border-radius: 5px;
        color: #fff;
        padding: 10px;
        margin-bottom: 20px;
        cursor: pointer;
        transition: background 0.3s;
      }

      .new-chat-btn:hover {
        background: #6b6c80;
      }

      .chat-list {
        flex: 1;
        overflow-y: auto;
      }

      .chat-item {
        padding: 10px;
        margin: 5px 0;
        border-radius: 5px;
        cursor: pointer;
        transition: background 0.3s;
        color: #fff;
      }

      .chat-item:hover {
        background: #2a2b32;
      }

      .chat-item.active {
        background: #2a2b32;
      }

      .main-content {
        flex: 1;
        display: flex;
        flex-direction: column;
        height: 100vh;
      }

      .chat-container {
        flex: 1;
        overflow-y: auto;
        padding: 20px;
      }

      .message {
        max-width: 800px;
        margin: 20px auto;
        padding: 20px;
        border-radius: 5px;
        white-space: pre-wrap;
      }

      .user-message {
        background: #343541;
      }

      .bot-message {
        background: #444654;
      }

      .input-container {
        padding: 20px;
        background: #343541;
        border-top: 1px solid #4a4b53;
      }

      .message-input {
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
        display: block;
        background: #40414f;
        border: 1px solid #565869;
        border-radius: 5px;
        padding: 12px;
        color: #fff;
        font-size: 16px;
        resize: none;
        min-height: 52px;
        outline: none;
      }

      .user-section {
        padding: 10px;
        border-top: 1px solid #4a4b53;
        margin-top: auto;
      }

      .loading {
        text-align: center;
        color: #565869;
        padding: 20px;
      }

      #errorMessage {
        color: #ff4444;
        text-align: center;
        padding: 10px;
        display: none;
      }
    </style>
  </head>
  <body>
    <div class="sidebar">
      <button class="new-chat-btn" onclick="createNewChat()">Новый чат</button>
      <div class="chat-list" id="chatList">
        <!-- Чаты будут добавлены динамически -->
      </div>
      <div class="user-section">
        <span id="userName">Пользователь</span>
        <button onclick="logout()" style="margin-left: 10px">Выйти</button>
      </div>
    </div>

    <div class="main-content">
      <div id="errorMessage"></div>
      <div class="chat-container" id="chatContainer">
        <!-- Сообщения будут добавлены динамически -->
      </div>
      <div class="input-container">
        <textarea
          class="message-input"
          placeholder="Напишите сообщение..."
          id="messageInput"
          rows="1"
        ></textarea>
      </div>
    </div>

    <script>
      let socket;
      let currentChatId = null;
      const API_URL = "http://localhost:3000";

      // Проверяем авторизацию при загрузке
      async function checkAuth() {
        const token = localStorage.getItem("token");
        if (!token) {
          window.location.href = "/login.ejs";
          return;
        }

        try {
          const response = await fetch(`${API_URL}/auth/profile`, {
            headers: {
              Authorization: `Bearer ${token}`,
            },
          });

          if (!response.ok) {
            throw new Error("Unauthorized");
          }

          const user = await response.json();
          document.getElementById("userName").textContent =
            user.name || user.email;

          // После успешной авторизации подключаемся к WebSocket
          connectWebSocket();
          loadChats();
        } catch (error) {
          console.error("Auth error:", error);
          window.location.href = "/login.ejs";
        }
      }

      // Подключение к WebSocket
      function connectWebSocket() {
        const token = localStorage.getItem("token");
        socket = io(`${API_URL}/socket.io`, {
          transports: ["websocket"],
          query: { token },
        });

        socket.on("connect", () => {
          console.log("WebSocket Connected");
        });

        socket.on("error", (error) => {
          showError(error.message);
        });

        socket.on("receive_message", (data) => {
          appendMessage(data.userMessage.content, true);
          appendMessage(data.aiMessage.content, false);
        });

        socket.on("message_sent", (data) => {
          appendMessage(data.userMessage.content, true);
          appendMessage(data.aiMessage.content, false);
        });

        socket.on("joined_chat", (data) => {
          currentChatId = data.chatId;
          document.getElementById("chatContainer").innerHTML = "";
          data.messages?.forEach((msg) => {
            appendMessage(msg.content, msg.sender === "user");
          });
        });

        // Отправка heartbeat каждые 30 секунд
        setInterval(() => {
          socket.emit("heartbeat");
        }, 30000);
      }

      // Загрузка списка чатов
      async function loadChats() {
        try {
          const token = localStorage.getItem("token");
          const response = await fetch(`${API_URL}/chats/my`, {
            headers: {
              Authorization: `Bearer ${token}`,
            },
          });
          const chats = await response.json();
          const chatList = document.getElementById("chatList");
          chatList.innerHTML = "";
          chats.forEach(addChatToList);
        } catch (error) {
          showError("Ошибка загрузки чатов");
        }
      }

      // Создание нового чата
      async function createNewChat() {
        try {
          const token = localStorage.getItem("token");
          const response = await fetch(`${API_URL}/chats/create`, {
            method: "POST",
            headers: {
              Authorization: `Bearer ${token}`,
              "Content-Type": "application/json",
            },
            body: JSON.stringify({ title: "Новый чат" }),
          });
          const chat = await response.json();
          addChatToList(chat);
          joinChat(chat.id);
        } catch (error) {
          showError("Ошибка создания чата");
        }
      }

      // Добавление чата в список
      function addChatToList(chat) {
        const chatList = document.getElementById("chatList");
        const chatElement = document.createElement("div");
        chatElement.className = "chat-item";
        chatElement.textContent = chat.title || `Чат ${chat.id}`;
        chatElement.onclick = () => joinChat(chat.id);
        chatElement.dataset.chatId = chat.id;
        chatList.appendChild(chatElement);
      }

      // Присоединение к чату
      function joinChat(chatId) {
        document.querySelectorAll(".chat-item").forEach((item) => {
          item.classList.remove("active");
          if (item.dataset.chatId === chatId) {
            item.classList.add("active");
          }
        });

        socket.emit("join_chat", { chatId });
        currentChatId = chatId;
        document.getElementById("chatContainer").innerHTML = "";
      }

      // Отправка сообщения
      function sendMessage() {
        const input = document.getElementById("messageInput");
        const message = input.value.trim();

        if (message && currentChatId) {
          socket.emit("send_message", {
            chatId: currentChatId,
            message: message,
          });

          input.value = "";
        }
      }

      // Добавление сообщения в чат
      function appendMessage(content, isUser) {
        const container = document.getElementById("chatContainer");
        const messageDiv = document.createElement("div");
        messageDiv.className = `message ${
          isUser ? "user-message" : "bot-message"
        }`;
        messageDiv.textContent = content;
        container.appendChild(messageDiv);
        container.scrollTop = container.scrollHeight;
      }

      // Показ ошибки
      function showError(message) {
        const errorDiv = document.getElementById("errorMessage");
        errorDiv.textContent = message;
        errorDiv.style.display = "block";
        setTimeout(() => {
          errorDiv.style.display = "none";
        }, 5000);
      }

      function logout() {
        localStorage.removeItem("token");
        window.location.href = "/login.ejs";
      }

      document.addEventListener("DOMContentLoaded", () => {
        checkAuth();

        const messageInput = document.getElementById("messageInput");
        messageInput.addEventListener("keypress", (e) => {
          if (e.key === "Enter" && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
          }
        });
      });
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.4.1/socket.io.min.js"></script>
  </body>
</html>
